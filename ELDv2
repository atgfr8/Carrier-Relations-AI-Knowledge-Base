<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ELD Exemption Guide — V4</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --atg-teal: #0069A6;
  --atg-teal-dark: #004F7C;
  --atg-teal-light: #E6F2F9;
  --atg-teal-mid: #CCE4F1;
  --atg-navy: #1A2E44;
  --bg: #D6E3ED;
  --surface: #FFFFFF;
  --surface-2: #EBF0F5;
  --border: #C8D8E4;
  --border-dark: #8AAFC5;
  --ink: #1A2E44;
  --ink-mid: #4A6478;
  --ink-light: #8AAFC5;
  --hard-bg: #FDF0EF;
  --hard-border: #E8A09C;
  --hard-text: #8B2220;
  --hard-dot: #D64340;
  --eld-bg: #EDFAF4;
  --eld-border: #8ED4B0;
  --eld-text: #0E5C38;
  --eld-dot: #1A9458;
  --amber: #C98F00;
  --amber-light: #FDF5E8;
  --amber-border: #E8C87A;
  --mono: 'IBM Plex Mono', monospace;
  --body: 'IBM Plex Sans', sans-serif;
  --radius: 6px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--body); background: var(--bg); color: var(--ink); font-size: 14px; line-height: 1.5; min-height: 100vh; }

/* ── HEADER ── */
.header {
  background: var(--atg-navy); border-bottom: 3px solid var(--atg-teal);
  padding: 12px 24px; display: flex; align-items: center;
  justify-content: space-between; position: sticky; top: 0; z-index: 100;
}
.header-brand { display: flex; align-items: center; gap: 14px; }
.atg-logo strong { font-size: 16px; font-weight: 700; letter-spacing: 2px; color: #fff; text-transform: uppercase; }
.atg-logo span { font-size: 8px; font-weight: 400; letter-spacing: 4px; color: rgba(255,255,255,0.5); text-transform: uppercase; display: block; }
.header-div { width: 1px; height: 24px; background: rgba(255,255,255,0.15); }
.header-title { font-size: 15px; font-weight: 600; color: #fff; }
.header-meta { font-family: var(--mono); font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 0.05em; }

/* ── LAYOUT ── */
.layout { display: grid; grid-template-columns: 1fr 320px; min-height: calc(100vh - 55px); }

/* ── LEFT PANEL ── */
.left { padding: 20px 24px; overflow-y: auto; }

/* Accordion cards */
.acc { background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius); margin-bottom: 8px; overflow: hidden; }
.acc-header { display: flex; align-items: center; justify-content: space-between; padding: 11px 16px; cursor: pointer; user-select: none; }
.acc-header:hover { background: var(--surface-2); }
.acc-label { font-family: var(--mono); font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; color: var(--atg-teal); }
.acc-arrow { font-size: 10px; color: var(--ink-light); transition: transform 0.2s; }
.acc-arrow.open { transform: rotate(180deg); }
.acc-body { display: none; padding: 0 16px 14px; border-top: 1px solid var(--border); }
.acc-body.open { display: block; }
.acc-body p { font-size: 14px; color: var(--ink-mid); line-height: 1.7; font-style: italic; margin-bottom: 8px; }
.acc-body p:last-child { margin-bottom: 0; }
.opt-lbl { font-family: var(--mono); font-size: 10px; color: var(--atg-teal); text-transform: uppercase; letter-spacing: 0.06em; margin: 10px 0 4px; }
.opt-lbl:first-child { margin-top: 0; }
.acc-tip { background: var(--atg-teal-light); border-left: 2px solid var(--atg-teal); border-radius: 0 4px 4px 0; padding: 7px 11px; margin-bottom: 10px; font-size: 13px; color: var(--atg-teal-dark); line-height: 1.6; }
.acc-list { padding-left: 14px; }
.acc-list li { font-size: 13px; color: var(--ink-mid); line-height: 1.9; }
.acc-rule { font-size: 12px; color: var(--ink-mid); padding: 5px 0; border-bottom: 1px solid var(--border); line-height: 1.5; }
.acc-rule:last-child { border-bottom: none; }
.acc-rule strong { color: var(--ink); }

/* ── TRIAGE BLOCKS ── */
.block { background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius); margin-bottom: 10px; overflow: hidden; }
.block-title { font-family: var(--mono); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--ink-light); padding: 12px 18px 0; }
.block-body { padding: 12px 18px 16px; }

/* Q rows */
.q-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); }
.q-row:last-child { border-bottom: none; padding-bottom: 0; }
.q-row:first-child { padding-top: 0; }
.q-row.col { flex-direction: column; align-items: flex-start; gap: 8px; }
.q-label { font-size: 13px; font-weight: 500; color: var(--ink); flex: 1; line-height: 1.4; }
.q-sub { font-family: var(--mono); font-size: 10px; color: var(--ink-light); display: block; margin-top: 2px; }

/* Toggles */
.tog { display: flex; border: 1.5px solid var(--border-dark); border-radius: var(--radius); overflow: hidden; flex-shrink: 0; }
.tog-btn { padding: 6px 14px; font-family: var(--mono); font-size: 11px; font-weight: 500; background: none; border: none; border-right: 1px solid var(--border-dark); cursor: pointer; color: var(--ink-light); transition: all 0.15s; white-space: nowrap; }
.tog-btn:last-child { border-right: none; }
.tog-btn:hover { background: var(--atg-teal-light); color: var(--atg-teal-dark); }
.tog-btn.yes { background: var(--eld-bg); color: var(--eld-text); border-color: var(--eld-border); }
.tog-btn.no  { background: var(--hard-bg); color: var(--hard-text); border-color: var(--hard-border); }
.tog-btn.sel { background: var(--atg-teal-light); color: var(--atg-teal); border-color: var(--atg-teal-mid); }

/* Pills */
.pills { display: flex; flex-wrap: wrap; gap: 6px; }
.pill { padding: 5px 13px; border: 1.5px solid var(--border); border-radius: 99px; font-family: var(--mono); font-size: 11px; font-weight: 500; color: var(--ink-mid); background: var(--surface); cursor: pointer; transition: all 0.15s; user-select: none; }
.pill:hover { border-color: var(--atg-teal); color: var(--atg-teal); }
.pill.active { background: var(--atg-teal-mid); border-color: var(--atg-teal); color: var(--atg-teal-dark); font-weight: 600; }
.pill.active.high-risk { background: var(--hard-bg); border-color: var(--hard-border); color: var(--hard-text); }

/* Caveat */
.caveat { padding: 10px 14px; border: 1.5px solid var(--amber-border); border-left: 3px solid var(--amber); border-radius: 0 var(--radius) var(--radius) 0; background: var(--amber-light); font-size: 11px; font-weight: 500; color: #7A5200; line-height: 1.7; margin-top: 10px; }

/* Hidden */
.hidden { display: none !important; }

/* ── RIGHT PANEL ── */
.right { border-left: 1px solid var(--border); display: flex; flex-direction: column; position: sticky; top: 55px; height: calc(100vh - 55px); background: var(--surface); }

/* Reference section — top of right */
.ref-section { border-bottom: 1px solid var(--border); flex-shrink: 0; }
.exempt-strip { background: var(--atg-navy); padding: 9px 16px; display: flex; align-items: center; gap: 14px; }
.exempt-lbl { font-family: var(--mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.35); flex-shrink: 0; }
.exempt-item .en { font-family: var(--mono); font-size: 10px; font-weight: 600; color: #8DD4A8; }
.exempt-item .ec { font-size: 10px; color: rgba(255,255,255,0.4); }
.ref-tabs { display: flex; background: var(--surface-2); }
.ref-tab { flex: 1; padding: 8px 4px; text-align: center; font-family: var(--mono); font-size: 9px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; color: var(--ink-light); background: none; border: none; border-right: 1px solid var(--border); border-bottom: 2px solid transparent; cursor: pointer; transition: all 0.15s; }
.ref-tab:last-child { border-right: none; }
.ref-tab:hover { color: var(--ink); background: var(--surface); }
.ref-tab.active { color: var(--atg-teal); border-bottom-color: var(--atg-teal); background: var(--atg-teal-light); }
.ref-panel { display: none; padding: 12px 14px; max-height: 200px; overflow-y: auto; border-bottom: 1px solid var(--border); }
.ref-panel.open { display: block; }
.ref-panel p { font-size: 11px; color: var(--ink-mid); line-height: 1.7; font-style: italic; margin-bottom: 6px; }
.ref-panel p:last-child { margin-bottom: 0; }
.rp-lbl { font-family: var(--mono); font-size: 9px; color: var(--atg-teal); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 3px; margin-top: 8px; }
.rp-lbl:first-child { margin-top: 0; }
.rp-tip { background: var(--atg-teal-light); border-left: 2px solid var(--atg-teal); border-radius: 0 4px 4px 0; padding: 5px 9px; margin-bottom: 7px; font-size: 11px; color: var(--atg-teal-dark); line-height: 1.6; }
.rp-list { padding-left: 13px; margin-bottom: 4px; }
.rp-list li { font-size: 11px; color: var(--ink-mid); line-height: 1.8; }
.rp-rule { font-size: 11px; color: var(--ink-mid); padding: 3px 0; border-bottom: 1px solid var(--border); line-height: 1.5; }
.rp-rule:last-child { border-bottom: none; }
.rp-rule strong { color: var(--ink); }

/* Live result */
.live-result { flex: 1; padding: 16px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
.pending-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 8px; color: var(--ink-light); }
.pending-state .pi { font-size: 28px; opacity: 0.3; }
.pending-state p { font-size: 11px; line-height: 1.6; max-width: 180px; }

/* Result badge */
.r-badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 99px; font-family: var(--mono); font-size: 11px; font-weight: 500; border: 1px solid; margin-bottom: 8px; }
.r-badge.exempt { background: var(--eld-bg); color: var(--eld-text); border-color: var(--eld-border); }
.r-badge.notexempt { background: var(--hard-bg); color: var(--hard-text); border-color: var(--hard-border); }
.r-badge.conditional { background: var(--amber-light); color: var(--amber); border-color: var(--amber-border); }

.r-title { font-size: 17px; font-weight: 600; color: var(--ink); margin-bottom: 6px; line-height: 1.3; }
.r-detail { font-size: 12px; color: var(--ink-mid); line-height: 1.65; margin-bottom: 10px; }

/* Denial tags */
.denial-wrap { margin-bottom: 10px; }
.denial-lbl { font-family: var(--mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--hard-dot); margin-bottom: 5px; }
.denial-tags { display: flex; flex-wrap: wrap; gap: 4px; }
.d-tag { padding: 2px 8px; border-radius: 4px; background: var(--hard-bg); border: 1px solid var(--hard-border); font-family: var(--mono); font-size: 10px; color: var(--hard-text); }

/* Override pill */
.override-pill { display: inline-flex; align-items: center; gap: 7px; padding: 5px 11px; background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 10px; }
.override-pill .ol { font-family: var(--mono); font-size: 10px; color: var(--ink-light); }
.override-pill .ov { font-family: var(--mono); font-size: 12px; font-weight: 600; }
.ov.green { color: var(--eld-text); }
.ov.amber { color: var(--amber); }

/* Note + response */
.r-note { background: var(--atg-teal-light); border-left: 2px solid var(--atg-teal); border-radius: 0 var(--radius) var(--radius) 0; padding: 9px 11px; margin-bottom: 8px; }
.r-note .nl { font-family: var(--mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--atg-teal); margin-bottom: 3px; }
.r-note p { font-size: 11px; color: var(--atg-teal-dark); line-height: 1.6; }
.r-resp { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius); padding: 9px 11px; }
.r-resp .rl { font-family: var(--mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-light); margin-bottom: 3px; }
.r-resp p { font-size: 11px; color: var(--ink-mid); line-height: 1.7; font-style: italic; }

/* Risk meter */
.risk-bar-wrap { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: var(--surface-2); border-radius: var(--radius); border: 1px solid var(--border); }
.risk-bar-lbl { font-family: var(--mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-light); white-space: nowrap; }
.risk-bar { flex: 1; height: 3px; background: var(--border); border-radius: 3px; overflow: hidden; }
.risk-fill { height: 100%; border-radius: 3px; transition: all 0.4s ease; width: 0; }
.risk-val { font-family: var(--mono); font-size: 10px; font-weight: 600; white-space: nowrap; }

/* Reset */
.reset-btn { padding: 9px; background: var(--surface-2); border: 1.5px solid var(--border); border-radius: var(--radius); font-family: var(--mono); font-size: 11px; color: var(--ink-light); cursor: pointer; transition: all 0.15s; text-align: center; width: 100%; flex-shrink: 0; margin: 0 16px 16px; width: calc(100% - 32px); }
.reset-btn:hover { border-color: var(--atg-teal); color: var(--atg-teal); }

/* Exception buttons */
.exc-btn { padding: 9px 14px; background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius); font-size: 13px; font-family: var(--body); color: var(--ink-mid); cursor: pointer; text-align: left; transition: all 0.15s; }
.exc-btn:hover { border-color: var(--atg-teal); color: var(--atg-teal); background: var(--atg-teal-light); }

@keyframes fadeUp { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
.fade { animation: fadeUp 0.2s ease; }
</style>
</head>
<body>

<div class="header">
  <div class="header-brand">
    <div class="atg-logo">
      <strong>Armstrong</strong>
      <span>Transport Group</span>
    </div>
    <div class="header-div"></div>
    <span class="header-title">ELD Exemption Guide <span style="font-family:var(--mono);font-size:10px;color:rgba(255,255,255,0.35);margin-left:4px;">V4</span></span>
  </div>
  <div class="header-meta">Updated <span id="mod-date"></span></div>
</div>

<div class="layout">

  <!-- ── LEFT: TRIAGE INPUTS ── -->
  <div class="left">

    <!-- Reference Accordions -->
    <div class="acc">
      <div class="acc-header" onclick="toggleAcc('acc-responses')">
        <span class="acc-label">💬 Opening Responses <span style="font-weight:400;opacity:0.5;">(optional)</span></span>
        <span class="acc-arrow" id="arr-responses">▼</span>
      </div>
      <div class="acc-body" id="acc-responses">
        <div class="opt-lbl" style="margin-top:10px;">Option 1</div>
        <p>Just a heads up — we're tightening up our ELD process, so there are a few things we need to verify before we can activate.</p>
        <div class="opt-lbl">Option 2</div>
        <p>Just a heads up — we're tightening up our ELD policy. Having an active ELD connection helps us ensure the right carriers are where they're supposed to be, and is an important part of how we protect every load.</p>
        <div class="opt-lbl">Option 3</div>
        <p>For fastest reactivation: please have the carrier connect their ELD in Highway.<br><strong style="font-style:normal;color:var(--ink);">If claiming an equipment exemption</strong> — ask the carrier why they believe they qualify and send us the reason along with their cab card for review.<br><strong style="font-style:normal;color:var(--ink);">If requesting a policy exception</strong> (override on a restricted load type — e.g., dry van/reefer out of CA, HVHR): send the load number, equipment type, commodity, value, and lane along with the reason for the request.<br><span style="color:var(--ink-light);">Note: policy restrictions can nullify an equipment exemption.</span></p>
      </div>
    </div>

    <div class="acc">
      <div class="acc-header" onclick="toggleAcc('acc-ask')">
        <span class="acc-label">❓ What to Ask</span>
        <span class="acc-arrow" id="arr-ask">▼</span>
      </div>
      <div class="acc-body" id="acc-ask">
        <div class="acc-tip" style="margin-top:10px;">💡 Load # or MC alone can often give you equipment, commodity, value and lane without asking.</div>
        <div class="opt-lbl">Start here</div>
        <p style="font-style:normal;margin-bottom:6px;">Equipment type · Commodity · Cargo value · Lane</p>
        <div class="opt-lbl">Then branch into</div>
        <ul class="acc-list">
          <li>New or existing carrier?</li>
          <li>Loads in last 90 days?</li>
          <li>CA origin?</li>
          <li>Long haul over 1,000 miles?</li>
          <li>Exemption reason claimed?</li>
          <li>Cab card / title available?</li>
        </ul>
      </div>
    </div>

    <div class="acc">
      <div class="acc-header" onclick="toggleAcc('acc-sop')">
        <span class="acc-label">📝 Template Responses <span style="font-weight:400;opacity:0.5;">(optional)</span></span>
        <span class="acc-arrow" id="arr-sop">▼</span>
      </div>
      <div class="acc-body" id="acc-sop">
        <div class="acc-tip" style="margin-top:10px;">These are suggested responses you can copy and send. Adjust as needed for the situation.</div>
        <div class="opt-lbl">Request for Information</div>
        <p>To see if the carrier qualifies for a policy exemption, we'll need a few details. Please send us the load number, equipment type, commodity, estimated cargo value, and lane (origin and destination).</p>
        <div class="opt-lbl">ELD Required — General</div>
        <p>Hi — before we can proceed with activation, we need to verify the ELD status. Per our current policy, an active ELD connection is required. Please have the carrier connect their ELD via Highway and we'll be happy to move forward.</p>
        <div class="opt-lbl">New Carrier — ELD Required</div>
        <p>Hi — this carrier is showing as new in our system without prior load history with us. Per current policy, new carriers are required to have an active ELD connection to proceed. Please have the carrier connect their ELD via Highway.</p>
        <div class="opt-lbl">Exemption Under Review</div>
        <p>Hi — we received the exemption request and are reviewing it against our current policy. We'll follow up once we've completed our review. In the meantime, the fastest path to activation is to have the carrier connect their ELD via Highway.</p>
        <div class="opt-lbl">Override Approved</div>
        <p>Hi — we've reviewed the exemption and an override has been applied. Please note this override is valid for a limited time and the carrier will need to be re-evaluated before expiration. Overrides are subject to review and may be rescinded at any time.</p>
        <div class="opt-lbl">Denial — Hard Stop</div>
        <p>Hi — after reviewing this load against our current policy, we are unable to approve an ELD exemption at this time. An active ELD connection is required to proceed. Please have the carrier connect their ELD via Highway.</p>
      </div>
    </div>

    <!-- ── TRIAGE BLOCKS ── -->

    <!-- Block 1: Equipment & Model Year -->
    <div class="block">
      <div class="block-title">Equipment & Model Year</div>
      <div class="block-body">

        <div class="q-row">
          <div class="q-label">Model year 2001 to present?
            <span class="q-sub">Check Equipment in Highway</span>
          </div>
          <div class="tog">
            <button class="tog-btn" id="my-yes" onclick="set('modelYear', true,  'my-yes', 'my-no', 'yes')">YES</button>
            <button class="tog-btn" id="my-no"  onclick="set('modelYear', false, 'my-yes', 'my-no', 'no')">NO</button>
          </div>
        </div>

        <div class="q-row col">
          <div class="q-label">Equipment type</div>
          <div class="pills">
            <div class="pill" onclick="setEquip(this,'sprinter')">Sprinter / Hot Shot</div>
            <div class="pill high-risk" onclick="setEquip(this,'dryvan')">Dry Van</div>
            <div class="pill high-risk" onclick="setEquip(this,'reefer')">Reefer</div>
            <div class="pill" onclick="setEquip(this,'flatbed')">Flatbed</div>
            <div class="pill" onclick="setEquip(this,'stepdeck')">Step Deck / RGN</div>
            <div class="pill" onclick="setEquip(this,'drayage')">Drayage</div>
            <div class="pill" onclick="setEquip(this,'beam')">Beam Trailer</div>
            <div class="pill" onclick="setEquip(this,'other')">Other</div>
          </div>
        </div>

        <div class="q-row hidden" id="row-flatbed">
          <div class="q-label">High-risk flatbed cargo?
            <span class="q-sub">Metals, ATVs/UTVs, high-value or easily offloaded</span>
          </div>
          <div class="tog">
            <button class="tog-btn" id="fc-yes" onclick="set('flatbedCargo', true,  'fc-yes', 'fc-no', 'yes')">YES</button>
            <button class="tog-btn" id="fc-no"  onclick="set('flatbedCargo', false, 'fc-yes', 'fc-no', 'no')">NO</button>
          </div>
        </div>

      </div>
    </div>

    <!-- Block 2: Load Risk (dry van / reefer only) -->
    <div class="block hidden" id="block-risk">
      <div class="block-title">Load Risk</div>
      <div class="block-body">

        <div class="q-row">
          <div class="q-label">California origin?</div>
          <div class="tog">
            <button class="tog-btn" id="ca-yes" onclick="setCA(true)">YES</button>
            <button class="tog-btn" id="ca-no"  onclick="setCA(false)">NO</button>
          </div>
        </div>

        <div class="q-row">
          <div class="q-label">High value cargo above $100,000?</div>
          <div class="tog">
            <button class="tog-btn" id="hv-yes" onclick="setHV(true)">YES</button>
            <button class="tog-btn" id="hv-no"  onclick="setHV(false)">NO / Unknown</button>
          </div>
        </div>

        <div class="q-row hidden" id="row-lh">
          <div class="q-label">Long haul over 1,000 miles?
            <span class="q-sub">Relevant when CA origin is confirmed</span>
          </div>
          <div class="tog">
            <button class="tog-btn" id="lh-yes" onclick="set('lh', true,  'lh-yes', 'lh-no', 'yes')">YES</button>
            <button class="tog-btn" id="lh-no"  onclick="set('lh', false, 'lh-yes', 'lh-no', 'no')">NO</button>
          </div>
        </div>

      </div>
    </div>

