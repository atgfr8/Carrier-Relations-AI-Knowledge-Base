      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;padding:4px 0;">
        <span style="font-weight:500;color:var(--ink);">SMR LOGISTICS INC</span><span style="color:var(--ink-mid);">Sharon Rennie</span>
