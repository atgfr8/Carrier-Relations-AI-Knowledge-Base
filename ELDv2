<script>
// Date
const months=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const dm=new Date(document.lastModified);
document.getElementById("mod-date").textContent=`${months[dm.getMonth()]} ${dm.getDate()}, ${dm.getFullYear()}`;

// State
const s = { modelYear:null, equip:null, flatbedCargo:null, ca:null, hv:null, lh:null, carrier:null, history:null, cargo:null };
const equipLabels = { dryvan:'Dry Van', reefer:'Reefer', flatbed:'Flatbed', sprinter:'Sprinter / Hot Shot', stepdeck:'Step Deck / RGN', drayage:'Drayage', beam:'Beam Trailer', other:'Other' };
const NOTE_STD = "Inform the agent this override is valid for the stated duration. Upon expiration the carrier must be re-evaluated. This may change at the discretion of the Compliance Department.";

// Accordion toggle
function toggleAcc(id) {
  const body = document.getElementById(id);
  const key = id.replace('acc-','');
  const arrow = document.getElementById('arr-' + key);
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  arrow.classList.toggle('open', !isOpen);
}

// Ref tabs
function toggleRef(id) {
  const ids = ['rp-open','rp-ask','rp-sop'];
  const tabs = ['rt-open','rt-ask','rt-sop'];
  const isOpen = document.getElementById(id).classList.contains('open');
  ids.forEach(i => document.getElementById(i).classList.remove('open'));
  tabs.forEach(t => document.getElementById(t).classList.remove('active'));
  if (!isOpen) {
    document.getElementById(id).classList.add('open');
    tabs[ids.indexOf(id)] && document.getElementById(tabs[ids.indexOf(id)]).classList.add('active');
  }
}

// Generic toggle setter — clicking same value again deselects
function set(key, val, yesId, noId, type) {
  const currentBtn = document.getElementById(type === 'yes' ? yesId : noId);
  const alreadyActive = currentBtn.classList.contains(type === 'yes' ? 'yes' : 'no');

  if (alreadyActive) {
    // Deselect
    s[key] = null;
    document.getElementById(yesId).className = 'tog-btn';
    document.getElementById(noId).className  = 'tog-btn';
  } else {
    s[key] = val;
    document.getElementById(yesId).className = 'tog-btn' + (val ? ' yes' : '');
    document.getElementById(noId).className  = 'tog-btn' + (!val ? ' no'  : '');
  }

  // Special handling
  if (key === 'history') {
    document.getElementById('row-cargo').classList.toggle('hidden', s.history !== true || s.hv !== null);
    if (s.history === true && s.hv !== null) s.cargo = s.hv ? true : null;
    if (s.history === null) { s.cargo = null; document.getElementById('row-cargo').classList.add('hidden'); }
  }
  if (key === 'modelYear' && s.modelYear === null) {
    document.getElementById('block-carrier').classList.add('hidden');
    document.getElementById('block-history').classList.add('hidden');
  }
  evaluate();
}

// Equipment
function setEquip(el, val) {
  const wasActive = el.classList.contains('active');
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));

  if (wasActive) {
    s.equip = null;
    s.flatbedCargo = null;
    s.ca = null; s.hv = null; s.lh = null;
    document.getElementById('row-flatbed').classList.add('hidden');
    document.getElementById('block-risk').classList.add('hidden');
    document.getElementById('block-carrier').classList.add('hidden');
    document.getElementById('block-history').classList.add('hidden');
    resetRiskToggles();
    ['fc-yes','fc-no'].forEach(id => document.getElementById(id).className='tog-btn');
  } else {
    el.classList.add('active');
    s.equip = val;
    s.flatbedCargo = null;
    ['fc-yes','fc-no'].forEach(id => document.getElementById(id).className='tog-btn');
    document.getElementById('row-flatbed').classList.toggle('hidden', val !== 'flatbed');
    const needsRisk = (val === 'dryvan' || val === 'reefer') && s.modelYear !== false;
    document.getElementById('block-risk').classList.toggle('hidden', !needsRisk);
    if (!needsRisk) { s.ca = null; s.hv = null; s.lh = null; resetRiskToggles(); }
    const exempt = ['sprinter','drayage','stepdeck','beam'].includes(val);
    document.getElementById('block-carrier').classList.toggle('hidden', exempt || val === 'flatbed' || s.modelYear === false);
  }
  evaluate();
}

function resetRiskToggles() {
  ['ca-yes','ca-no','hv-yes','hv-no','lh-yes','lh-no'].forEach(id => document.getElementById(id).className = 'tog-btn');
  document.getElementById('row-lh').classList.add('hidden');
}

// CA
function setCA(val) {
  const btnId = val ? 'ca-yes' : 'ca-no';
  const alreadyActive = document.getElementById(btnId).classList.contains(val ? 'yes' : 'no');
  if (alreadyActive) {
    s.ca = null;
    document.getElementById('ca-yes').className = 'tog-btn';
    document.getElementById('ca-no').className  = 'tog-btn';
    document.getElementById('row-lh').classList.add('hidden');
    s.lh = null;
    document.getElementById('lh-yes').className='tog-btn';
    document.getElementById('lh-no').className='tog-btn';
  } else {
    s.ca = val;
    document.getElementById('ca-yes').className = 'tog-btn' + (val ? ' yes' : '');
    document.getElementById('ca-no').className  = 'tog-btn' + (!val ? ' no'  : '');
    document.getElementById('row-lh').classList.toggle('hidden', !val);
    if (!val) { s.lh = null; document.getElementById('lh-yes').className='tog-btn'; document.getElementById('lh-no').className='tog-btn'; }
  }
  evaluate();
}

// HV
function setHV(val) {
  const btnId = val ? 'hv-yes' : 'hv-no';
  const alreadyActive = document.getElementById(btnId).classList.contains(val ? 'yes' : 'no');
  if (alreadyActive) {
    s.hv = null;
    document.getElementById('hv-yes').className = 'tog-btn';
    document.getElementById('hv-no').className  = 'tog-btn';
  } else {
    s.hv = val;
    document.getElementById('hv-yes').className = 'tog-btn' + (val ? ' yes' : '');
    document.getElementById('hv-no').className  = 'tog-btn' + (!val ? ' no'  : '');
    if (s.history === true) { s.cargo = val ? true : null; document.getElementById('row-cargo').classList.add('hidden'); }
    if (s.ca === true && val === true) { evaluate(); return; }
    const exempt = ['sprinter','drayage','stepdeck','beam'].includes(s.equip);
    if (!exempt && s.equip !== 'flatbed' && s.modelYear !== false) {
      document.getElementById('block-carrier').classList.remove('hidden');
    }
  }
  evaluate();
}

// Carrier
function setCarrier(val) {
  const btnId = val === 'existing' ? 'c-existing' : 'c-new';
  const alreadyActive = document.getElementById(btnId).classList.contains('sel');
  if (alreadyActive) {
    s.carrier = null;
    s.history = null; s.cargo = null;
    document.getElementById('c-existing').className = 'tog-btn';
    document.getElementById('c-new').className      = 'tog-btn';
    document.getElementById('block-history').classList.add('hidden');
    ['h-yes','h-no','cv-yes','cv-no'].forEach(id => document.getElementById(id).className='tog-btn');
    document.getElementById('row-cargo').classList.add('hidden');
  } else {
    s.carrier = val;
    s.history = null; s.cargo = null;
    document.getElementById('c-existing').className = 'tog-btn' + (val === 'existing' ? ' sel' : '');
    document.getElementById('c-new').className      = 'tog-btn' + (val === 'new' ? ' sel' : '');
    document.getElementById('block-history').classList.toggle('hidden', val !== 'existing');
    ['h-yes','h-no','cv-yes','cv-no'].forEach(id => document.getElementById(id).className='tog-btn');
    document.getElementById('row-cargo').classList.add('hidden');
  }
  evaluate();
}

// Reset
function resetAll() {
  Object.keys(s).forEach(k => s[k]=null);
  document.querySelectorAll('.tog-btn').forEach(b => b.className='tog-btn');
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  ['block-risk','block-carrier','block-history','row-flatbed','row-lh','row-cargo'].forEach(id => document.getElementById(id).classList.add('hidden'));
  hideExceptions();
  document.getElementById('pending').style.display='flex';
  document.getElementById('verdict').style.display='none';
}

// Denial tags
function denialTags() {
  const t=[];
  if(s.equip) t.push(equipLabels[s.equip]);
  if(s.ca===true) t.push('CA Origin');
  if(s.hv===true) t.push('High Value >$100K');
  if(s.lh===true) t.push('Long Haul 1,000+ mi');
  if(s.carrier==='new') t.push('New Carrier');
  if(s.history===false) t.push('Insufficient Load History');
  if(s.cargo===true) t.push('Cargo >$100K');
  if(s.flatbedCargo===true) t.push('High-Risk Flatbed Cargo');
  return t;
}

// Dynamic response builder
function buildResponse(type) {
  const eq = equipLabels[s.equip] || 'this equipment';
  const origin = s.ca===true ? ' originating in California' : '';
  const hv = s.hv===true ? ' with high-value cargo above $100,000' : '';
  const lh = s.lh===true ? ' on a long-haul lane over 1,000 miles' : '';
  if(type==='exempt') {
    if(s.modelYear===false) return `Based on the pre-2000 engine on file, this carrier qualifies for an ELD exemption under current policy. An override has been applied and is valid for 6 months. Upon expiration, the carrier must be re-evaluated. Overrides are subject to review and may be rescinded at any time.`;
    if(['sprinter','drayage','stepdeck','beam'].includes(s.equip)||(s.equip==='flatbed'&&s.flatbedCargo===false)) return `Based on the equipment type on file (${eq}), this carrier qualifies for an ELD exemption under current policy. An override has been applied and is valid for 6 months. Upon expiration, the carrier must be re-evaluated. Overrides are subject to review and may be rescinded at any time.`;
    if(s.carrier==='existing'&&s.history===true) {
      const risk=(s.ca||s.lh)?` ⚠ Elevated risk${origin}${lh} — apply additional scrutiny.`:'';
      return `Based on verified load history, this ${eq} carrier qualifies for an ELD exemption. An override has been applied and is valid for 90 days. Upon expiration, the carrier must be re-evaluated.${risk} Overrides are subject to review and may be rescinded at any time.`;
    }
  }
  if(s.ca===true&&s.hv===true) return `We are unable to process an ELD exemption for this load. This ${eq} load${origin}${hv} presents a critical risk profile. An active ELD connection is required. Please have the carrier connect their ELD via Highway before this load can proceed.`;
  if(s.hv===true&&(s.equip==='dryvan'||s.equip==='reefer')) return `We are unable to process an ELD exemption for this ${eq} load${hv}. Per current policy, loads with cargo value above $100,000 require an active ELD connection. Please have the carrier connect their ELD via Highway.`;
  if(s.equip==='flatbed'&&s.flatbedCargo===true) return `We are unable to process an ELD exemption for this flatbed load. The cargo type requires an active ELD connection per current policy. Please have the carrier connect their ELD via Highway.`;
  if(s.carrier==='new'&&(s.equip==='dryvan'||s.equip==='reefer')) return `We are unable to process an ELD exemption for this load. This is a new carrier on a ${eq} load${origin}${hv}. Per current policy, new carriers on dry van and reefer loads require an active ELD connection. Please have the carrier connect their ELD via Highway.`;
  if(s.carrier==='new') return `We are unable to process an ELD exemption for this load. This is a new carrier without prior load history with us. Per current policy, new carriers are required to have an active ELD connection. If they believe they qualify for an exception, please send us the reason along with their cab card.`;
  if(s.carrier==='existing'&&s.history===false&&(s.equip==='dryvan'||s.equip==='reefer')) return `We are unable to process an ELD exemption for this ${eq} load${origin}. This carrier does not meet the minimum load history requirement, and dry van and reefer loads require an active ELD connection. Please have the carrier connect their ELD via Highway.`;
  if(s.carrier==='existing'&&s.history===false) return `We are unable to process an ELD exemption for this load. This carrier does not meet the minimum load history requirement of 3 completed loads in the last 90 days. If they believe they qualify for an exception, please send the load number, equipment type, commodity, value, and lane along with the reason.`;
  if(s.cargo===true) return `We are unable to process an ELD exemption for this load. The cargo value exceeds $100,000, which is a hard stop under current policy. An active ELD connection is required. Please have the carrier connect their ELD via Highway.`;
  return `Per current policy, an active ELD connection is required for this load. Please have the carrier connect their ELD via Highway to proceed.`;
}

// Show result
function showResult(type, title, detail, override, note, response) {
  const badges = { exempt:'✓ Exempt', notexempt:'✗ Not Exempt', conditional:'⚠ Conditional' };
  const tags = type==='notexempt' ? denialTags() : [];
  const tagsHtml = tags.length ? `<div class="denial-wrap"><div class="denial-lbl">Denial Factors</div><div class="denial-tags">${tags.map(t=>`<span class="d-tag">${t}</span>`).join('')}</div></div>` : '';
  const overrideHtml = override ? `<div class="override-pill"><span class="ol">Override</span><span class="ov ${type==='exempt'?'green':'amber'}">${override}</span></div>` : '';
  const noteHtml = note ? `<div class="r-note"><div class="nl">Note</div><p>${note}</p></div>` : '';
  const respHtml = response ? `<div class="r-resp"><div class="rl">💬 Suggested Response</div><p id="r-live-resp">${response}</p></div>` : `<div class="r-resp"><div class="rl">💬 Suggested Response</div><p id="r-live-resp" style="color:var(--ink-light);font-style:normal;">Building response...</p></div>`;
  // Risk meter
  const riskFactors = [s.ca===true, s.hv===true, s.lh===true, s.carrier==='new'||s.history===false].filter(Boolean);
  const riskPct = Math.min(riskFactors.length / 3 * 100, 100);
  const riskColor = riskPct===0?'var(--eld-dot)':riskPct<=33?'var(--eld-dot)':riskPct<=66?'var(--amber)':'var(--hard-dot)';
  const riskLabel = riskPct===0?'Low':riskPct<=33?'Low':riskPct<=66?'Moderate':'High';
  const riskHtml = riskFactors.length > 0 ? `<div class="risk-bar-wrap"><span class="risk-bar-lbl">Risk</span><div class="risk-bar"><div class="risk-fill" style="width:${riskPct}%;background:${riskColor};"></div></div><span class="risk-val" style="color:${riskColor};">${riskLabel}</span></div>` : '';

  document.getElementById('pending').style.display='none';
  const v=document.getElementById('verdict');
  v.style.display='block';
  v.className='fade';
  v.innerHTML=`${riskHtml}<div style="margin-top:${riskHtml?'10px':'0'};"><span class="r-badge ${type}">${badges[type]}</span><div class="r-title">${title}</div><div class="r-detail">${detail}</div>${tagsHtml}${overrideHtml}${noteHtml}${respHtml}</div>`;
}

// Show exceptions block after not-exempt result
function showExceptions(allowNewCarrier, allowFull) {
  document.getElementById('block-exceptions').classList.remove('hidden');
  document.getElementById('exc-btn-newcarrier').style.display = allowNewCarrier ? 'block' : 'none';
  // Reset all exception rows
  ['exc-row-shorthaul','exc-row-incompatible','exc-row-glider','exc-row-newcarrier'].forEach(id => document.getElementById(id).classList.add('hidden'));
  ['sh-consistent','sh-situational','inc-yes','inc-no','gl-yes','gl-no','nc-yes','nc-no'].forEach(id => document.getElementById(id).className='tog-btn');
  document.getElementById('exc-buttons').style.display='flex';
}

function hideExceptions() {
  document.getElementById('block-exceptions').classList.add('hidden');
}

function showExcRow(id) {
  document.getElementById('exc-buttons').style.display='none';
  ['exc-row-shorthaul','exc-row-incompatible','exc-row-glider','exc-row-newcarrier'].forEach(r => document.getElementById(r).classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
}

function setException(type) {
  const NOTE_30 = "Inform the agent this is a 30-day conditional override only. The carrier must be re-evaluated at expiration. Overrides are subject to review and may be rescinded at any time.";
  const NOTE_6  = "Inform the agent this override is valid for 6 months. Upon expiration the carrier must be re-evaluated. This may change at the discretion of the Compliance Department.";

  if(type==='shorthaul_consistent') {
    document.getElementById('sh-consistent').className='tog-btn yes';
    document.getElementById('sh-situational').className='tog-btn';
    showResult('exempt','Exempt — Consistent Short-Haul Operator','Carrier routinely operates under 150 air miles. Route history verified. Qualifies for short-haul exemption.','6 months',NOTE_6,'Based on verified route history, this carrier qualifies for a short-haul ELD exemption. An override has been applied and is valid for 6 months. Upon expiration the carrier must be re-evaluated. Overrides are subject to review and may be rescinded at any time.');
  } else if(type==='shorthaul_situational') {
    document.getElementById('sh-situational').className='tog-btn sel';
    document.getElementById('sh-consistent').className='tog-btn';
    showResult('conditional','Conditional — Situational Short-Haul','This specific load is under 150 air miles, but the carrier has not established a consistent short-haul pattern.','30 days',NOTE_30,'A conditional override has been applied for this load based on the route falling within 150 air miles. This override is valid for 30 days only and does not establish an ongoing exemption.');
  } else if(type==='incompatible_yes') {
    document.getElementById('inc-yes').className='tog-btn yes';
    document.getElementById('inc-no').className='tog-btn';
    showResult('conditional','Conditional — Incompatible ELD Provider','All required documentation provided. Macropoint/Trucker Tools required. No loads over $100K permitted during this override.','30 days','Macropoint or Trucker Tools must be active. This override cannot apply to any load over $100K. '+NOTE_30,'A conditional override has been applied based on the documentation provided. This override is valid for 30 days. Macropoint or Trucker Tools must remain active and it cannot apply to loads over $100,000.');
  } else if(type==='incompatible_no') {
    document.getElementById('inc-no').className='tog-btn no';
    document.getElementById('inc-yes').className='tog-btn';
    showResult('notexempt','Not Exempt — Missing Documentation','Required documentation for incompatible ELD provider exception was not provided. ELD connection required.',null,null,'Based on our review, the required documentation for this exception was not provided. Please have the carrier connect their ELD via Highway to proceed.');
  } else if(type==='glider_yes') {
    document.getElementById('gl-yes').className='tog-btn yes';
    document.getElementById('gl-no').className='tog-btn';
    showResult('exempt','Exempt — Glider Kit (Pre-2000 Engine Verified)','Standard exemption documentation plus engine year verification confirmed.','6 months',NOTE_6,'Based on the verified engine documentation provided, this carrier qualifies for an ELD exemption. An override has been applied and is valid for 6 months. Overrides are subject to review and may be rescinded at any time.');
  } else if(type==='glider_no') {
    document.getElementById('gl-no').className='tog-btn no';
    document.getElementById('gl-yes').className='tog-btn';
    showResult('notexempt','Not Exempt — Glider Kit Documentation Missing','Engine year must be verified with a physical document — invoice, work order, or engine tag. Self-reported year alone is not sufficient.',null,null,'We are unable to process this exemption without verified engine documentation. Please provide an invoice, work order, or engine tag confirming the pre-2000 engine year.');
  } else if(type==='newcarrier_yes') {
    document.getElementById('nc-yes').className='tog-btn yes';
    document.getElementById('nc-no').className='tog-btn';
    showResult('conditional','Rare Override — New Carrier','All rare override criteria are met. This is an exception and should be handled with additional scrutiny.','24 hours','This is not a standard path. Ensure all criteria are documented before granting any override. Overrides are subject to review and may be rescinded at any time.','A limited override has been applied based on the documentation provided. This override is valid for 24 hours only and is not a standard exemption. All criteria must be on file before this load proceeds.');
  } else if(type==='newcarrier_no') {
    document.getElementById('nc-no').className='tog-btn no';
    document.getElementById('nc-yes').className='tog-btn';
    showResult('notexempt','Not Exempt — New Carrier','The rare override criteria were not fully met. ELD connection is required.',null,null,'Our records indicate this is a new carrier. The criteria for a rare override were not met. Please have the carrier connect their ELD via Highway to proceed.');
  }
}

// Live suggested response — updates inside the result panel
function buildLiveResponse() {
  const parts = [];
  const eq = equipLabels[s.equip];

  if (!s.equip && s.modelYear === null) return;

  parts.push("Hi — we're reviewing this");
  if (s.carrier === 'new') parts.push("new carrier");
  else parts.push("carrier");
  if (eq) parts.push(`on a ${eq} load`);
  if (s.ca === true) parts.push("originating in California");
  if (s.hv === true) parts.push("with high-value cargo above $100,000");
  if (s.lh === true) parts.push("on a long-haul lane over 1,000 miles");
  if (s.history === false) parts.push("that does not meet our minimum load history requirement");
  else if (s.history === true) parts.push("with verified load history");

  let sentence = parts.join(", ").replace(", on a", " on a").replace(", that", " that").replace(", with verified", " with verified") + ".";

  if (s.ca === true && s.hv === true) {
    sentence += " This load presents a critical risk profile under our current policy. An active ELD connection is required — we are unable to proceed with an ELD exemption.";
  } else if (s.hv === true && (s.equip === 'dryvan' || s.equip === 'reefer')) {
    sentence += " Per current policy, loads with cargo value above $100,000 require an active ELD connection. We are unable to approve an ELD exemption for this load.";
  } else if (s.carrier === 'new' && (s.equip === 'dryvan' || s.equip === 'reefer')) {
    sentence += " Per current policy, new carriers on dry van and reefer loads are required to have an active ELD connection. We are unable to approve an ELD exemption for this load.";
  } else if (s.equip === 'flatbed' && s.flatbedCargo === true) {
    sentence += " Per current policy, this cargo type requires an active ELD connection. We are unable to approve an ELD exemption.";
  } else if (s.history === false) {
    sentence += " Per current policy, a minimum of 3 completed loads within the last 90 days is required for an ELD exemption.";
  } else if (['sprinter','drayage','stepdeck','beam'].includes(s.equip) || s.modelYear === false || (s.equip === 'flatbed' && s.flatbedCargo === false)) {
    sentence += " Based on the equipment type on file, this carrier qualifies for an ELD exemption under current policy.";
  } else if (s.history === true) {
    sentence += " Based on verified load history, this carrier qualifies for an ELD exemption under current policy.";
  } else {
    sentence += " We are reviewing the ELD exemption eligibility against our current policy.";
  }

  if (!['sprinter','drayage','stepdeck','beam'].includes(s.equip) && s.modelYear !== false && !(s.equip === 'flatbed' && s.flatbedCargo === false) && s.history !== true) {
    sentence += " Please have the carrier connect their ELD via Highway to proceed.";
  }

  // Update the response inside the verdict if it exists
  const respEl = document.getElementById('r-live-resp');
  if (respEl) respEl.textContent = sentence;
}

// Main evaluate — fires on every state change
function evaluate() {
  buildLiveResponse();
  // Pre-2000
  if(s.modelYear===false) { showResult('exempt','Exempt by Model Year','Pre-2000 engine confirmed. No further evaluation needed.','6 months',null,buildResponse('exempt')); hideExceptions(); return; }
  // Sprinter
  if(s.equip==='sprinter') { showResult('exempt','Exempt by Equipment Type','Sprinter van or hot shot (Class 1 or 2).','6 months',null,buildResponse('exempt')); hideExceptions(); return; }
  // Drayage
  if(s.equip==='drayage') { showResult('exempt','Exempt — Drayage','Drayage equipment qualifies for ELD exemption.','6 months',null,buildResponse('exempt')); hideExceptions(); return; }
  // Step Deck / RGN
  if(s.equip==='stepdeck') { showResult('exempt','Exempt — Step Deck / RGN','Step deck or RGN qualifies for ELD exemption.','6 months',null,buildResponse('exempt')); hideExceptions(); return; }
  // Beam
  if(s.equip==='beam') { showResult('exempt','Exempt — Beam Trailer','Beam trailer qualifies for ELD exemption.','6 months',null,buildResponse('exempt')); hideExceptions(); return; }
  // Flatbed high-risk
  if(s.equip==='flatbed'&&s.flatbedCargo===true) { showResult('notexempt','Not Exempt — High-Risk Flatbed Cargo','Flatbed carriers hauling metals, ATVs/UTVs, or high-value/easily-offloaded cargo must connect a valid ELD.',null,null,buildResponse('notexempt')); hideExceptions(); return; }
  // Flatbed standard
  if(s.equip==='flatbed'&&s.flatbedCargo===false) { showResult('exempt','Exempt — Flatbed (Standard Cargo)','Flatbed with standard cargo qualifies for ELD exemption.','6 months',null,buildResponse('exempt')); hideExceptions(); return; }
  // CA + HV critical
  if(s.ca===true&&s.hv===true) { showResult('notexempt','Not Exempt — Critical Risk Load','California origin combined with high-value cargo represents the highest theft risk profile. ELD required.',null,null,buildResponse('notexempt')); hideExceptions(); return; }
  // HV alone on dry van/reefer
  if(s.hv===true&&(s.equip==='dryvan'||s.equip==='reefer')) { showResult('notexempt','Not Exempt — High Value Cargo','Dry van and reefer loads with cargo value above $100,000 require an active ELD connection.',null,null,buildResponse('notexempt')); hideExceptions(); return; }
  // New carrier + dry van/reefer
  if(s.carrier==='new'&&(s.equip==='dryvan'||s.equip==='reefer')) { showResult('notexempt','Not Exempt — New Carrier (Dry Van / Reefer)','New carriers on dry van or reefer loads are not eligible for ELD exemption.',null,null,buildResponse('notexempt')); showExceptions(false); return; }
  // New carrier + other
  if(s.carrier==='new'&&s.equip&&s.equip!=='dryvan'&&s.equip!=='reefer') { showResult('notexempt','Not Exempt — New Carrier','New carriers generally cannot qualify via load history. Request carrier to connect their ELD.',null,'A specific, valid reason is required before any override can be considered.',buildResponse('notexempt')); showExceptions(true); return; }
  // Existing + history qualifies
  if(s.carrier==='existing'&&s.history===true) {
    if(s.cargo===true) { showResult('notexempt','Not Exempt — Cargo Value Exceeds $100,000','No ELD exemption override can be granted when cargo value is above $100,000.',null,null,buildResponse('notexempt')); showExceptions(false); return; }
    const riskFlags=[];
    if(s.ca===true) riskFlags.push('California origin');
    if(s.lh===true) riskFlags.push('long haul over 1,000 miles');
    const note=riskFlags.length?NOTE_STD+` ⚠ Elevated risk: ${riskFlags.join(', ')} — apply additional scrutiny.`:NOTE_STD;
    showResult('exempt','Exempt by Load History','Existing carrier with 3+ completed loads in the last 90 days.','90 days',null,buildResponse('exempt'));
    hideExceptions();
    return;
  }
  // Existing + thin + dry van/reefer
  if(s.carrier==='existing'&&s.history===false&&(s.equip==='dryvan'||s.equip==='reefer')) { showResult('notexempt','Not Exempt — Insufficient Load History (Dry Van / Reefer)','This carrier does not meet the load history requirement and is on a dry van or reefer load.',null,null,buildResponse('notexempt')); showExceptions(false); return; }
  // Existing + thin + other
  if(s.carrier==='existing'&&s.history===false) { showResult('notexempt','Not Exempt — Insufficient Load History','The carrier does not have 3+ completed loads in the last 90 days.',null,'Ask the carrier to connect their ELD via Highway. If they claim an exception, they can submit documentation for review.',buildResponse('notexempt')); showExceptions(false, true); return; }
  // Not enough info yet
  document.getElementById('pending').style.display='flex';
  document.getElementById('verdict').style.display='none';
}
